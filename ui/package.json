{
	"name": "jentic-one-ui",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"codegen": "openapi --input openapi.json --output src/shared/api/generated --client fetch --useOptions",
		"gen:favicons": "node scripts/gen-favicons.mjs",
		"test": "vitest",
		"test:run": "vitest run",
		"test:lint": "vitest run --config vitest.lint.config.ts",
		"test:coverage": "vitest run --coverage",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:docker": "playwright test --config=playwright.docker.config.ts"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.101.2",
		"clsx": "^2.1.1",
		"framer-motion": "^12.40.0",
		"lucide-react": "^1.21.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.18.1",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-istanbul": "^4.1.5",
		"axe-core": "^4.12.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.7.0",
		"msw": "^2.15.0",
		"openapi-typescript-codegen": "^0.31.0",
		"pg": "^8.22.0",
		"png-to-ico": "^3.0.2",
		"prettier": "^3.9.5",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sharp": "^0.35.3",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.4"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
