__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
build/
dist/
wheels/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# uv
.uv/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# IDE / editors
.idea/
.vscode/
*.swp
